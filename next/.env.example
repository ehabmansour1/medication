# MongoDB Atlas connection string
# Get it from: Atlas dashboard → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name to use inside the cluster
MONGODB_DB=medication

# Vercel Blob token (for lab result image uploads)
# Get it from: Vercel project → Storage → Create a Blob store → connect → auto-injected.
# Locally: copy the token from your Vercel project env into .env.local.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Web Push (VAPID) keys for medication-day reminders.
# Generate once with: npx web-push generate-vapid-keys
# Set the public key in NEXT_PUBLIC_ so the browser can read it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email shown to push services if there's a problem.
VAPID_CONTACT=mailto:you@example.com

# Random string used to authenticate Vercel Cron calls to /api/cron/*.
# Vercel auto-injects this when you set it; cron requests arrive with
# Authorization: Bearer ${CRON_SECRET}.
CRON_SECRET=

# App login credentials (single user). The password is compared in plain text.
AUTH_USERNAME=ahmed
AUTH_PASSWORD=9745
# HMAC secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

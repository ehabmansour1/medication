# MongoDB Atlas connection string
# Get it from: Atlas dashboard → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name to use inside the cluster
MONGODB_DB=medication

# Vercel Blob token (for lab result image uploads)
# Get it from: Vercel project → Storage → Create a Blob store → connect → auto-injected.
# Locally: copy the token from your Vercel project env into .env.local.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
